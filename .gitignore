# ============================================================
# EcoQuest — .gitignore
# ============================================================

# ─── Node Modules (NEVER commit these) ──────────────────────
node_modules/
backend/node_modules/
frontend/node_modules/

# ─── Environment / Secret Files ─────────────────────────────
# Root level
.env
.env.*
!.env.example

# Backend secrets
backend/.env
backend/.env.*
!backend/.env.example
backend/.env.docker

# Frontend secrets (if any)
frontend/.env
frontend/.env.*
!frontend/.env.example

# ─── Build & Dist Output ────────────────────────────────────
dist/
build/
frontend/dist/
frontend/build/
backend/dist/

# ─── Uploaded User Files ─────────────────────────────────────
backend/uploads/

# ─── Docker Volumes / DB Data ───────────────────────────────
mongo_data/
*.db
*.sqlite

# ─── Logs ───────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
logs/
backend/logs/

# ─── OS / System Files ──────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
desktop.ini

# ─── Editor / IDE ───────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── Temporary / Cache Files ────────────────────────────────
.cache/
.parcel-cache/
.vite/
*.tmp
*.temp

# ─── Coverage & Testing ─────────────────────────────────────
coverage/
.nyc_output/

# ─── Package Manager Lock Conflicts ─────────────────────────
# (keep package-lock.json, ignore yarn.lock if using npm)
yarn.lock
