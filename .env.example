# ============================================================
# .env.example — SAFE TO COMMIT (no real credentials)
# Copy this file to .env and fill in your values
# ============================================================

# MongoDB Atlas (Local Development)
# Special chars in password MUST be URL-encoded:
#   # → %23
#   @ → %40
# Example: mongodb+srv://user:%23pass%40word@cluster.mongodb.net/ecoquest
MONGO_URI=mongodb+srv://<DB_USER>:<URL_ENCODED_PASSWORD>@<CLUSTER>.mongodb.net/ecoquest

# JWT Secret — use any long random string
JWT_SECRET=your_random_jwt_secret_here_min_32_chars

# Server Port
PORT=5000

# Environment
NODE_ENV=development
